{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grimorio",
  "version": "0.2.2",
  "identifier": "com.gedasio.grimorio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Grimório",
        "width": 1400,
        "height": 900,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": { "enable": true, "scope": ["**"] }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlCMTA4Mjc2NUNDRTg4NTAKUldSUWlNNWNkb0lRbTNvVWpERlRabjBFN1JJR1BRdldGalNhTWthRmdlQzNLdk9uZkNjb1orZjUK",
      "endpoints": [
        "https://github.com/GedasioSaga/grimorio/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
